{
  "schemaVersion": 1,
  "id": "thematic-anim",
  "version": "${version}",
  "name": "Thematic Animator (Player Animator)",
  "description": "A lightweight library to easily animate the player",
  "authors": [
    "KosmX  "
  ],
  "contact": {
    "homepage": "kosmx.dev",
    "sources": "https://github.com/KosmX/fabricPlayerAnimation"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "client": [
      "com.funalex.themAnim.fabric.client.FabricClientInitializer"
    ]
  },
  "mixins": [
    "themAnimator-common.mixins.json"
  ],
  "depends": {
    "fabric-resource-loader-v0": "*"
  },
  "breaks": {
    "bettercombat": "<1.6.0"
  },
  "custom": {
    "modmenu": {
      "badges": ["library"]
    }
  }
}